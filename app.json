{
  "expo": {
    "name": "The OGs",
    "slug": "The-OGs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/todoappicon.png",
    "scheme": "theogs",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/todoappicon.png",
        "backgroundImage": "./assets/images/todoappicon.png",
        "monochromeImage": "./assets/images/todoappicon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.the_ogs.app"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "infoPlist": {
              "NSAppTransportSecurity": {
                "NSAllowsArbitraryLoads": true
              }
            }
          }
        }
      ],
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/Quantico-Regular.ttf",
            "./src/assets/fonts/Quantico-Bold.ttf"
          ]
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}